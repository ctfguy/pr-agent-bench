# Required for analysis
OPENAI_API_KEY=

# Strongly recommended to avoid GitHub API rate limits
GITHUB_TOKEN=

# Models
OPENAI_MODEL=gpt-5-mini
OPENAI_VALIDATOR_MODEL=gpt-5-mini
AGENT_WORKERS=5

# Advisory selection for make prod-run
ADVISORY=GHSA-jpx3-25r2-jq5g
URL=
LIMIT=
SEVERITY=critical

# Local Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=advisory-miner

# Local Langfuse project initialized by docker-compose.infra.yml
LANGFUSE_PUBLIC_KEY=pk-lf-advisory-local
LANGFUSE_SECRET_KEY=sk-lf-advisory-local
LANGFUSE_BASE_URL=http://localhost:3100

# App persistence
ADVISORY_MINER_DATABASE_URL=postgresql://advisory:advisory@localhost:5545/advisory_miner

# Local cache/results
REPO_CACHE_DIR=.cache/repos
RESULTS_DIR=results
GITHUB_TOKEN=ghp_replace_me
OPENAI_API_KEY=sk_replace_me
# Any OpenAI model that supports the Responses API and parallel function tools.
# OPENAI_MODEL drives the investigator tool-loop; OPENAI_VALIDATOR_MODEL is used
# for the post-hoc model reviewer. Both default to gpt-5-mini; override here.
OPENAI_MODEL=gpt-5-mini
OPENAI_VALIDATOR_MODEL=gpt-5-mini
AGENT_WORKERS=5
AGENT_COST_CAP_USD=0.50
REPO_CACHE_DIR=.cache/repos
ADVISORY_MINER_DB=.cache/advisory_miner.sqlite3
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=advisory-miner
LANGFUSE_PUBLIC_KEY=pk-lf-advisory-local
LANGFUSE_SECRET_KEY=sk-lf-advisory-local
LANGFUSE_HOST=http://localhost:3100
